[req]
default_bits = 2048
prompt = no
default_md = sha256
x509_extensions = v3_req
distinguished_name = dn

[dn]
C = KR
ST = Seoul
L = Seoul
O = SIPLite
OU = Dev
CN = 192.168.0.23

[v3_req]
subjectAltName = @alt_names

[alt_names]
# Update these entries to match the hostname or IP Linphone will use.
IP.1 = 192.168.0.23
DNS.1 = sip.local
